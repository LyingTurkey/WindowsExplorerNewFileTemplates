Windows Registry Editor Version 5.00

; --- REMOVE CUSTOM JAVASCRIPT SHORTCUTS ---
[-HKEY_CLASSES_ROOT\.js\ShellNew]
[-HKEY_CLASSES_ROOT\JSFile]

; --- REMOVE CUSTOM PYTHON SHORTCUTS ---
[-HKEY_CLASSES_ROOT\.py\ShellNew]
[-HKEY_CLASSES_ROOT\PythonFile]

; --- REMOVE CUSTOM REGISTRY SHORTCUTS ---
[-HKEY_CLASSES_ROOT\.reg\ShellNew]

; --- REMOVE CUSTOM BATCH SHORTCUTS ---
[-HKEY_CLASSES_ROOT\.bat\ShellNew]